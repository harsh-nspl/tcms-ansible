pipeline {
    agent any

    parameters {
        string(name: 'BRANCH', defaultValue: 'release/4.9.4', description: 'Git branch')
    }

    options {
        timestamps()
        timeout(time: 60, unit: 'MINUTES')
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '5'))
    }

    environment {
        HOST_BUILD_DIR = "/opt/builds"
        REPO_NAME = "aio-tcms-frontend-v2"
        CONFIG_REPO_NAME = "aio-tcms-env-config"
    }

    stages {
        stage('Checkout & Build') {
            steps {
                tcmsNpmBuild(
                    repoName: env.REPO_NAME,
                    configRepo: env.CONFIG_REPO_NAME,
                    buildScript: 'build-dev'
                )
            }
        }

        stage('Deploy Frontend') {
            steps {
                tcmsFrontendDeploy(
                    repoName: env.REPO_NAME,
                    staticPath: '/var/www/html/aio-tcms/aiotcms-static'
                )
            }
        }

        stage('Build & Deploy Forge') {
            steps {
                tcmsForgeDeploy(
                    repoName: env.REPO_NAME,
                    forgeEnv: 'development-new'
                )
            }
        }
    }

    post {
        success {
            echo "✅ Frontend deployment successful (branch: ${params.BRANCH})"
        }
        failure {
            echo "❌ Frontend deployment failed (branch: ${params.BRANCH})"
        }
        always {
            cleanWs()
        }
    }
}
