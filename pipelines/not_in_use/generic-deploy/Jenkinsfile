pipeline {
    agent {
        docker {
            image 'willhallonline/ansible:latest'
            args '-u root'
        }
    }

    parameters {
        choice(
            name: 'ENV',
            choices: ['dev', 'stage', 'prod'],
            description: 'Environment'
        )

        string(name: 'COMPONENT', description: 'Component to deploy')
        string(name: 'HOST_GROUP', description: 'Target host group')
    }

    environment {
        ANSIBLE_CONFIG = 'ansible/ansible.cfg'
    }

    options {
        timestamps()
        timeout(time: 30, unit: 'MINUTES')
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Validate Input') {
            steps {
                script {
                    if (!params.COMPONENT?.trim()) {
                        error "COMPONENT is required"
                    }
                    if (!params.HOST_GROUP?.trim()) {
                        error "HOST_GROUP is required"
                    }

                    env.INVENTORY = "ansible/inventories/${params.ENV}/hosts.ini"
                    env.PLAYBOOK  = "ansible/playbooks/${params.COMPONENT}.yml"
                }
            }
        }

        stage('Validate Inventory') {
            steps {
                sh 'ansible-inventory -i ${INVENTORY} --list'
            }
        }

        stage('Ping Hosts') {
            steps {
                sshagent(["ssh-key"]) {
                    sh """
                        ansible -i ${INVENTORY} ${params.HOST_GROUP} -m ping
                    """
                }
            }
        }

        stage('Deploy') {
            steps {
                sshagent(["ssh-key"]) {
                    sh """
                        ansible-playbook \
                            -i ${INVENTORY} \
                            ${PLAYBOOK} \
                            --limit ${params.HOST_GROUP}
                    """
                }
            }
        }
    }

    post {
        success {
            echo "✅ ${params.COMPONENT} deployed to ${params.ENV}"
        }
        failure {
            echo "❌ Deployment failed for ${params.COMPONENT}"
        }
    }
}